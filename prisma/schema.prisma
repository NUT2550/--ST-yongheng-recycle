generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model ProductCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  type      String // STEEL, METAL
  sortOrder Int       @default(0)
  products  Product[]
}

model Product {
  id                 String                      @id @default(cuid())
  name               String                      @unique
  categoryId         String
  category           ProductCategory             @relation(fields: [categoryId], references: [id])
  defaultBuyPrice    Float                       @default(0)
  sortOrder          Int                         @default(0)
  stockLots          StockLot[]
  buyItems           BuyBillItem[]
  sellItems          SellBillItem[]
  sortingSource      SortingBill[]               @relation("SortingSource")
  sortingItems       SortingBillItem[]
  transferSource     StockTransfer[]             @relation("TransferSource")
  transferItems      StockTransferItem[]
  physicalCountItems PhysicalCountItem[]
  dailyWeighingItems DailyPurchaseWeighingItem[]
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
}

model StockLot {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  remainingWeight Float
  costPerKg       Float
  dateAdded       DateTime @default(now())
  source          String // BUY, SORTING
  sourceId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BuyBill {
  id                 String        @id @default(cuid())
  billNumber         String?       @unique
  externalBillNumber String?       @unique // เลขบิลจากระบบเดิม (Excel import)
  date               DateTime      @default(now())
  isCredit           Boolean       @default(false)
  note               String?
  items              BuyBillItem[]
  totalAmount        Float         @default(0)
  isCancelled        Boolean       @default(false)
  cancelledAt        DateTime?
  cancelledBy        String?
  cancelReason       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model BuyBillItem {
  id               String  @id @default(cuid())
  buyBillId        String
  buyBill          BuyBill @relation(fields: [buyBillId], references: [id], onDelete: Cascade)
  productId        String
  product          Product @relation(fields: [productId], references: [id])
  weight           Float
  weightExpression String? // สูตรที่ผู้ใช้พิมพ์ เช่น "860-3" (null = กรอกตัวเลขตรงๆ)
  pricePerKg       Float
  totalAmount      Float
}

model SellBill {
  id                 String         @id @default(cuid())
  billNumber         String?        @unique
  externalBillNumber String?        @unique // เลขบิลจากระบบเดิม (Excel import) — used for duplicate detection
  date               DateTime       @default(now())
  customerId         String?
  customer           Customer?      @relation(fields: [customerId], references: [id])
  isCredit           Boolean        @default(false)
  note               String?
  items              SellBillItem[]
  totalAmount        Float          @default(0)
  totalCost          Float          @default(0)
  isCancelled        Boolean        @default(false)
  cancelledAt        DateTime?
  cancelledBy        String?
  cancelReason       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model SellBillItem {
  id               String   @id @default(cuid())
  sellBillId       String
  sellBill         SellBill @relation(fields: [sellBillId], references: [id], onDelete: Cascade)
  productId        String
  product          Product  @relation(fields: [productId], references: [id])
  weight           Float
  weightExpression String? // สูตรที่ผู้ใช้พิมพ์ เช่น "860-3"
  pricePerKg       Float
  totalAmount      Float
  costPerKg        Float    @default(0)
  totalCost        Float    @default(0)
}

model SortingBill {
  id                     String            @id @default(cuid())
  billNumber             String?           @unique
  date                   DateTime          @default(now())
  sourceProductId        String
  sourceProduct          Product           @relation("SortingSource", fields: [sourceProductId], references: [id])
  sourceWeight           Float
  sourceWeightExpression String? // สูตรน้ำหนักต้นทาง เช่น "68.4-0.2"
  sourcePricePerKg       Float             @default(0) // ราคารับซื้อสินค้าต้นทาง (พนักงานใส่, ใช้คิดโบนัส)
  weighedTotal           Float             @default(0)
  weighedTotalExpression String? // สูตรน้ำหนักชั่งรวม
  lossWeight             Float             @default(0)
  lossCost               Float             @default(0)
  roomNumber             String? // เลขห้อง (dedicated field; do not use note for room)
  note                   String?
  items                  SortingBillItem[]
  bonuses                SortingBonus[]
  isCancelled            Boolean           @default(false)
  cancelledAt            DateTime?
  cancelledBy            String?
  cancelReason           String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

model SortingBillItem {
  id               String      @id @default(cuid())
  sortingBillId    String
  sortingBill      SortingBill @relation(fields: [sortingBillId], references: [id], onDelete: Cascade)
  productId        String
  product          Product     @relation(fields: [productId], references: [id])
  weight           Float
  weightExpression String? // สูตรน้ำหนักที่คัดแยกได้ เช่น "22-0.2"
  isWaste          Boolean     @default(false)
  costPerKg        Float       @default(0) // ต้นทุน FIFO (บัญชี)
  totalCost        Float       @default(0)
  sortedPricePerKg Float       @default(0) // ราคารับซื้อสินค้าที่คัดได้ (พนักงานใส่)
  bonusAmount      Float       @default(0) // โบนัส = (sortedPricePerKg - sourcePricePerKg) * weight * 10%
}

// แกะของ/ย้ายสต็อก — consume 1 source product, produce N output products.
// Structurally similar to SortingBill but has NO bonus fields/relations.
// Keeps bonus-calculation logic fully isolated.
model StockTransfer {
  id                     String              @id @default(cuid())
  billNumber             String?             @unique
  date                   DateTime            @default(now())
  roomNumber             String? // เลขห้อง (dedicated field; do not use note for room)
  businessType           String? // คัดแยก | แกะของ | null — business classification for History tab display (null/empty = แกะของ default)
  // Source (consumed via FIFO)
  sourceProductId        String
  sourceProduct          Product             @relation("TransferSource", fields: [sourceProductId], references: [id])
  sourceWeight           Float
  sourceWeightExpression String? // สูตรน้ำหนักต้นทาง เช่น "100-0.5"
  sourceCostPerKg        Float               @default(0) // FIFO weighted-avg cost of consumed lots (stored for audit)
  sourceTotalCost        Float               @default(0) // sourceWeight * sourceCostPerKg (FIFO accounting cost)
  // Profitability analysis fields (manually entered, separate from FIFO stock cost)
  sourcePricePerKg       Float               @default(0) // ราคาต้นทาง/กก. (manual entry for profitability)
  laborCost              Float               @default(0) // เวลา/ค่าแรง (manual entry)
  outputTotalValue       Float               @default(0) // sum(outputWeight * outputPricePerKg) — calculated
  profitLoss             Float               @default(0) // outputTotalValue - (sourceWeight * sourcePricePerKg) - laborCost
  // Outputs summary
  weighedTotal           Float               @default(0) // optional manual weighed total (cross-check)
  weighedTotalExpression String?
  lossWeight             Float               @default(0) // sourceWeight - sum(output weights)
  lossCost               Float               @default(0) // lossWeight * sourceCostPerKg
  note                   String?
  items                  StockTransferItem[]
  isCancelled            Boolean             @default(false)
  cancelledAt            DateTime?
  cancelledBy            String?
  cancelReason           String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
}

model StockTransferItem {
  id               String        @id @default(cuid())
  stockTransferId  String
  stockTransfer    StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  productId        String
  product          Product       @relation(fields: [productId], references: [id])
  weight           Float
  weightExpression String? // สูตรน้ำหนัก output เช่น "20-0.1"
  isWaste          Boolean       @default(false) // ขยะ/สูญเสีย row — no stock lot created
  costPerKg        Float         @default(0) // allocated source cost (FIFO avg)
  totalCost        Float         @default(0)
  outputPricePerKg Float         @default(0) // ราคาปลายทาง/กก. (manual entry for profitability analysis)
  // NOTE: no bonusAmount — dismantle has no worker bonus
}

model Customer {
  id          String        @id @default(cuid())
  name        String
  phone       String?
  sellBills   SellBill[]
  creditEntry CreditEntry[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model CreditEntry {
  id            String          @id @default(cuid())
  type          String // RECEIVABLE (ค้างรับ), PAYABLE (ค้างจ่าย)
  amount        Float
  paidAmount    Float           @default(0)
  customerId    String? // Only for RECEIVABLE
  customer      Customer?       @relation(fields: [customerId], references: [id])
  referenceType String // BUY_BILL, SELL_BILL
  referenceId   String?
  description   String?
  date          DateTime        @default(now())
  isSettled     Boolean         @default(false)
  payments      CreditPayment[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model CreditPayment {
  id            String      @id @default(cuid())
  creditEntryId String
  creditEntry   CreditEntry @relation(fields: [creditEntryId], references: [id], onDelete: Cascade)
  amount        Float
  date          DateTime    @default(now())
  note          String?
  createdAt     DateTime    @default(now())
}

model Employee {
  id        String         @id @default(cuid())
  name      String
  phone     String?
  hireDate  DateTime? // วันเริ่มงาน (ใช้คำนวณสัดส่วนโบนัส)
  isActive  Boolean        @default(true)
  bonuses   SortingBonus[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model SortingBonus {
  id            String       @id @default(cuid())
  date          DateTime     @default(now())
  employeeId    String
  employee      Employee     @relation(fields: [employeeId], references: [id])
  sortingBillId String?
  sortingBill   SortingBill? @relation(fields: [sortingBillId], references: [id])
  totalWeight   Float        @default(0) // น้ำหนักรวมที่คัดแยก
  ratePerKg     Float        @default(0) // อัตราโบนัส บาท/กก.
  totalAmount   Float        @default(0) // ยอดโบนัสรวม
  note          String?
  isPaid        Boolean      @default(false)
  paidDate      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String
  name        String
  role        String   @default("staff") // admin, staff
  permissions String? // JSON array of permission strings e.g. ["customer.create","buy.create"]; null = no extra permissions (admin gets all implicitly via role)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Audit log for tracking create/edit/delete/cancel actions on bills
model AuditLog {
  id         String   @id @default(cuid())
  action     String // CREATE, UPDATE, DELETE, CANCEL
  entityType String // BUY_BILL, SELL_BILL, SORTING_BILL, STOCK_TRANSFER, PHYSICAL_COUNT, USER_PERMISSION
  entityId   String
  userId     String?
  userName   String?
  details    String? // JSON string of changes/summary
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ST-14: Compensation Operation Ledger — persistent operation tracking for
// crash-safe, retry-safe rollback. An Operation has multiple Items (one per lot).
// Retry with same requestId resumes the existing Operation, skipping COMPLETED items.
model CompensationOperation {
  id             String    @id @default(cuid())
  requestId      String    @unique // client/server request ID — one operation per request
  operationType  String // STOCK_TRANSFER_CREATE, PHYSICAL_COUNT_APPLY, etc.
  sourceEntityId String? // optional: the bill/session ID that failed
  status         String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  error          String? // error message if FAILED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime? // set when status = COMPLETED

  items CompensationItem[]

  @@index([requestId])
  @@index([status])
}

// ST-14: Compensation Item — one per StockLot to restore. Tracks per-lot status.
model CompensationItem {
  id           String                @id @default(cuid())
  operationId  String // FK to CompensationOperation
  operation    CompensationOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  lotId        String // StockLot.id to restore
  amount       Float // weight to restore
  beforeWeight Float // lot.remainingWeight before compensation (for audit)
  afterWeight  Float? // lot.remainingWeight after compensation (set when COMPLETED)
  status       String                @default("PENDING") // PENDING, COMPLETED, FAILED
  error        String? // error message if FAILED
  completedAt  DateTime? // set when status = COMPLETED

  @@unique([operationId, lotId]) // one item per lot per operation
  @@index([operationId])
  @@index([lotId])
  @@index([status])
}

// Physical count session for end-of-day stock verification
model PhysicalCountSession {
  id           String              @id @default(cuid())
  countDate    DateTime
  group        String // ทองแดง, ทองเหลือง
  status       String              @default("DRAFT") // DRAFT, APPLIED
  note         String?
  // ST-9: Structured apply metadata (replaces note-based tracking)
  appliedById  String? // null = not applied; userId of who applied
  appliedAt    DateTime? // null = not applied; timestamp of apply
  appliedNote  String? // optional note entered at apply time (separate from draft note)
  // ST-9: Reversal reference (for future reversal-adjustment feature)
  reversalOfId String? // if this session is a reversal, points to original session ID
  items        PhysicalCountItem[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([countDate])
  @@index([group])
  @@index([appliedById])
}

model PhysicalCountItem {
  id               String               @id @default(cuid())
  sessionId        String
  session          PhysicalCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId        String
  product          Product              @relation(fields: [productId], references: [id])
  systemWeight     Float
  physicalWeight   Float                @default(0)
  differenceWeight Float                @default(0)
  averageCost      Float                @default(0)
  valueDifference  Float                @default(0)
  note             String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([sessionId])
  @@index([productId])
}

// ST-35: Daily Purchase Weighing — audit/verification of daily copper/brass purchases.
// This does NOT modify stock. It records the difference between purchased weight
// (from BuyBills) and actual weighed weight at end of day.
model DailyPurchaseWeighingSession {
  id           String   @id @default(cuid())
  weighingDate DateTime
  category     String // ทองแดง, ทองเหลือง
  status       String   @default("SAVED") // SAVED (locked, cannot edit)
  note         String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items DailyPurchaseWeighingItem[]

  @@unique([weighingDate, category]) // One session per date + category
  @@index([weighingDate])
  @@index([category])
}

model DailyPurchaseWeighingItem {
  id        String                       @id @default(cuid())
  sessionId String
  session   DailyPurchaseWeighingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId String
  product   Product                      @relation(fields: [productId], references: [id])

  // ST-38: source-breakdown snapshot at save time (server-computed, client never sends these).
  // The application-facing field is `purchaseWeight` (clearer than the original ST-35 name
  // `purchasedWeight`), but the physical PostgreSQL column is kept as `purchasedWeight`
  // via @map for zero-downtime backward compatibility with the currently-deployed ST-35 code.
  // ST-38 migration only ADDs the 5 new source-breakdown columns; it does NOT rename.
  purchaseWeight          Float @default(0) @map("purchasedWeight") // physical column retained for backward compat
  purchaseBillCount       Int   @default(0) // Snapshot: how many BuyBills had this product
  sortingOutputWeight     Float @default(0) // Snapshot from SortingBillItem (isWaste=false) + StockTransferItem (isWaste=false, businessType='คัดแยก')
  sortingBillCount        Int   @default(0) // Snapshot: how many SortingBills + sorting-type StockTransfers had this product
  dismantlingOutputWeight Float @default(0) // Snapshot from StockTransferItem (isWaste=false, businessType='แกะของ' or null/blank)
  dismantlingRecordCount  Int   @default(0) // Snapshot: how many dismantling-type StockTransfers had this product
  expectedTotalWeight     Float @default(0) // Snapshot: purchaseWeight + sortingOutputWeight + dismantlingOutputWeight (basis for difference)

  actualWeighedWeight Float? // null = not weighed yet; 0 = weighed and got zero
  differenceWeight    Float? // null = not calculated; actual - expectedTotalWeight
  status              String // MATCH, DIFFERENCE, NOT_WEIGHED
  note                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([productId])
}
